---
import Button from "@/components/starwind/button/Button.astro";
import { localizePath, localeFromPathname, pathWithoutLocale, resolveLocale, t, type Locale } from "@/lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props as Props;
const locale = resolveLocale(localeProp, localeFromPathname(Astro.url.pathname));
const text = t(locale);

function withLocale(pathname: string, nextLocale: Locale = locale): string {
  return localizePath(pathname, nextLocale);
}

const currentPath = pathWithoutLocale(Astro.url.pathname);
const currentSearchAndHash = `${Astro.url.search}${Astro.url.hash}`;
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/", label: text.navHome },
  { href: "/lessons/intro", label: text.navLessons },
  { href: "/about", label: text.navAbout },
];
---

<footer class="border-t border-border/60 bg-muted/35">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-8 px-6 py-8 md:flex-row md:items-start md:justify-between">
    <div class="space-y-2">
      <a href={withLocale('/')} class="inline-block text-lg font-semibold tracking-tight hover:opacity-80 transition-opacity">
        {text.siteTitle}
      </a>
      <p class="text-sm text-muted-foreground">© {currentYear} TIRS. {text.footerRights}</p>
    </div>

    <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:gap-8">
      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-muted-foreground">{text.footerNavigation}</p>
        <nav class="flex flex-col gap-1">
          {navLinks.map(({ href, label }) => (
            <a
              href={withLocale(href)}
              class="rounded-md px-2 py-1 text-sm text-foreground/80 transition-colors hover:bg-muted hover:text-foreground"
            >
              {label}
            </a>
          ))}
        </nav>
      </div>

      <div>
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.14em] text-muted-foreground">{text.footerLanguage}</p>
        <div class="flex gap-2">
          <Button
            variant="outline"
            size="sm"
            href={`${withLocale(currentPath, 'fr')}${currentSearchAndHash}`}
            class:list={[locale === 'fr' && 'bg-muted']}
          >
            {text.langFr}
          </Button>
          <Button
            variant="outline"
            size="sm"
            href={`${withLocale(currentPath, 'en')}${currentSearchAndHash}`}
            class:list={[locale === 'en' && 'bg-muted']}
          >
            {text.langEn}
          </Button>
        </div>
      </div>
    </div>
  </div>
</footer>
