---
import Button from "@/components/starwind/button/Button.astro";
import ButtonGroup from "@/components/starwind/button-group/ButtonGroup.astro";
import Separator from "@/components/starwind/separator/Separator.astro";
import Item from "@/components/starwind/item/Item.astro";
import ThemeToggle from "@/components/starwind/theme-toggle/ThemeToggle.astro";
import {
  Sheet,
  SheetTrigger,
  SheetContent,
  SheetHeader,
  SheetTitle,
} from "@/components/starwind/sheet";
import {
  localizePath,
  localeFromPathname,
  pathWithoutLocale,
  resolveLocale,
  t,
  withBasePath,
  type Locale,
} from "@/lib/i18n";

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props as Props;
const locale = resolveLocale(localeProp, localeFromPathname(Astro.url.pathname));
const text = t(locale);

function withLocale(pathname: string, nextLocale: Locale = locale): string {
  return localizePath(pathname, nextLocale);
}

const currentPath = pathWithoutLocale(Astro.url.pathname);
const currentSearchAndHash = `${Astro.url.search}${Astro.url.hash}`;

const navLinks = [
  { href: "/", label: text.navHome },
  { href: "/lessons/intro", label: text.navLessons },
  { href: "/about", label: text.navAbout },
];
---

<header class="bg-brand-gradient text-primary-foreground">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between gap-4">

    <!-- Logo / Titre -->
    <a
      href={withLocale('/')}
      class="flex items-center gap-3 text-2xl font-semibold tracking-tight text-primary-foreground hover:opacity-80 transition-opacity"
    >
      <img src={withBasePath('/logo.png')} alt="TIRS logo" class="h-8 w-auto object-contain" />
      <span>{text.siteTitle}</span>
    </a>

    <!-- Navigation desktop -->
    <nav class="hidden md:flex items-center gap-2">
      <ButtonGroup class="gap-1">
        {navLinks.map(({ href, label }) => (
          <Button
            variant="ghost"
            size="sm"
            href={withLocale(href)}
            class="text-primary-foreground hover:bg-primary-foreground/15 hover:text-primary-foreground focus-visible:ring-primary-foreground/40"
          >
            {label}
          </Button>
        ))}
      </ButtonGroup>
      <ThemeToggle
        size="sm"
        class="text-primary-foreground border-primary-foreground/30 hover:bg-primary-foreground/15 hover:data-[state=on]:bg-primary-foreground/15 hover:text-primary-foreground hover:border-primary-foreground/30 focus-visible:ring-primary-foreground/40"
        ariaLabel={text.changeTheme}
      />
    </nav>

    <!-- Menu mobile (Sheet) -->
    <div class="md:hidden flex items-center gap-2">
      <ThemeToggle
        size="sm"
        class="text-primary-foreground border-primary-foreground/30 hover:bg-primary-foreground/15 hover:data-[state=on]:bg-primary-foreground/15 hover:text-primary-foreground hover:border-primary-foreground/30 focus-visible:ring-primary-foreground/40"
        ariaLabel={text.changeTheme}
      />
      <Sheet>
        <SheetTrigger asChild>
          <Button
            variant="ghost"
            size="icon-sm"
            class="text-primary-foreground hover:bg-primary-foreground/15 hover:text-primary-foreground focus-visible:ring-primary-foreground/40"
            aria-label={text.openMenu}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </Button>
        </SheetTrigger>
        <SheetContent side="left">
          <SheetHeader>
            <SheetTitle>{text.siteTitle}</SheetTitle>
          </SheetHeader>
          <Separator />
          <nav class="flex flex-col gap-1 p-4">
            {navLinks.map(({ href, label }) => (
              <Item as="a" href={withLocale(href)} size="sm">
                {label}
              </Item>
            ))}
            <Separator />
          </nav>
        </SheetContent>
      </Sheet>
    </div>

  </div>
</header>
