---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import { t } from '@/lib/i18n';

const locale = 'en';
const text = t(locale);
---

<BaseLayout title={text.homeTitle} locale={locale}>
  <Header locale={locale} />
  <main class="prose mx-auto p-8">
    <h1>{text.homeHeading}</h1>
    <p>{text.homeIntro}</p>
    <a href="/en/lessons/intro" class="btn">{text.viewSampleLesson}</a>
    <h2>{text.availableLessons}</h2>
    <ul>
      <li><a href="/en/lessons/intro">{text.lessonIntro}</a></li>
      <li><a href="/en/lessons/history-of-astronomy-1">{text.lessonHistory1}</a></li>
      <li><a href="/en/lessons/history-of-astronomy-2">{text.lessonHistory2}</a></li>
    </ul>
  </main>
</BaseLayout>
